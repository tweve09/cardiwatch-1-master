<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <style>
    /* Modal styles */
.modal {
  display: none; /* Hide the modal by default */
  position: fixed;
  z-index: 999; /* Set a high z-index to ensure it appears above other elements */
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.4); /* Semi-transparent background overlay */
  overflow: auto;
}

.modal-content {
  background-color: #fff;
  margin: 10% auto; /* Center the modal vertically and horizontally */
  padding: 20px;
  border: 1px solid #888;
  width: 50%;
  max-width: 500px;
}

.modal-header {
  text-align: center;
  padding-bottom: 10px;
}

.modal-title {
  margin: 0;
}

.modal-body {
  padding-bottom: 20px;
}

.modal-footer {
  text-align: center;
}

/* Button styles */
button {
  padding: 8px 16px;
  border-radius: 4px;
  background-color: #ccc;
  border: none;
  color: #fff;
  cursor: pointer;
  margin-right: 10px;
}

button:hover {
  background-color: #555;
}

  </style>
</head>
<body>

  <form method="POST" action="/detail">
    <input type="hidden" name="patient_id" value="<%= result.id %>">
    <button class="btn btn-success" type="submit">View</button>
</form>

  <button id="openModalBtn">Open Modal</button>

<!-- The modal -->
<div id="myModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2 class="modal-title">Modal Title</h2>
    </div>
    <div class="modal-body">
      <p>Modal body text goes here.</p>
    </div>
    <div class="modal-footer">
      <button id="cancelBtn">Cancel</button>
      <button id="confirmBtn">Confirm</button>
    </div>
  </div>
</div>
<script>
  // Get the modal element
const modal = document.getElementById("myModal");

// Get the button that opens the modal
const openModalBtn = document.getElementById("openModalBtn");

// Get the cancel and confirm buttons
const cancelBtn = document.getElementById("cancelBtn");
const confirmBtn = document.getElementById("confirmBtn");

// Function to open the modal
function openModal() {
  modal.style.display = "block";
}

// Function to close the modal
function closeModal() {
  modal.style.display = "none";
}

// Attach click event listener to open the modal
openModalBtn.addEventListener("click", openModal);

// Attach click event listener to close the modal when cancel button is clicked
cancelBtn.addEventListener("click", closeModal);

// Attach click event listener to close the modal when confirm button is clicked
confirmBtn.addEventListener("click", closeModal);

</script>
</body>
</html>