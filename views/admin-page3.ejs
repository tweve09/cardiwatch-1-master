
<!DOCTYPE html>
<html>
<head>
  <title>CardiWatch</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-KK94CHFLLe+nY2dmCWGMq91rCGa5gtU4mk92HdvYe+M/SXH301p5ILy+dN9+nJOZ" crossorigin="anonymous">
  <style>
    .navbar{
      height: 70px;
      position: fixed;
      background-color: #f8f9fa;
      width: 100vw;
    }
    .user{
      margin-left: 65vw;
    }
    .navbar-container{
      display: flex;
      padding: 10px;
    }
    .left-div {
      position: fixed;
      top: 70px;
      left: 0;
      width: 200px;
      height: 100%;
      background-color: #f8f9fa;
    }
    
    .right-div {
      margin-left: 200px;
      height: calc(100vh - 70px);
      position: fixed;
      top: 70px;
      overflow-y: scroll;
      background-color: #fff;
      padding: 20px;
      width: calc(100vw - 200px);
    }
    .link-div{
      text-decoration: none;
      font-size: 20px;
    }
    .modal {
      display: none; /* Hide the modal by default */
      position: fixed;
      z-index: 999; /* Set a high z-index to ensure it appears above other elements */
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.4); /* Semi-transparent background overlay */
      overflow: auto;
    }
    
    .modal-content {
      background-color: #fff;
      margin: 10% auto; /* Center the modal vertically and horizontally */
      padding: 4px;
      border: 1px solid #888;
      width: 50%;
      max-width: 500px;
    }
    
    .modal-header {
      text-align: center;
      padding-bottom: 10px;
      background-color: #008894;
      color: white;
    }
    
    .modal-title {
      margin: 0;
    }
    
    .modal-body {
      padding-bottom: 10px;
      background-color: #f8f9fa;
    }
    
    .modal-footer {
      text-align: center;
    }
    .btn-custom{
      background-color: #008894;
    }
    .btn-custom:hover {
      background-color: #05b0bf;
    }
  </style>
</head>
<body>
  <div class="navbar">
    <div class="navbar-container">
      <div class="logo">
        <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="#008894" class="bi bi-heart-pulse-fill" viewBox="0 0 16 16">
          <path d="M1.475 9C2.702 10.84 4.779 12.871 8 15c3.221-2.129 5.298-4.16 6.525-6H12a.5.5 0 0 1-.464-.314l-1.457-3.642-1.598 5.593a.5.5 0 0 1-.945.049L5.889 6.568l-1.473 2.21A.5.5 0 0 1 4 9H1.475Z"/>
          <path d="M.88 8C-2.427 1.68 4.41-2 7.823 1.143c.06.055.119.112.176.171a3.12 3.12 0 0 1 .176-.17C11.59-2 18.426 1.68 15.12 8h-2.783l-1.874-4.686a.5.5 0 0 0-.945.049L7.921 8.956 6.464 5.314a.5.5 0 0 0-.88-.091L3.732 8H.88Z"/>
        </svg>
        <a class="navbar-brand ml-5 p-2">CardiWatch</a>
      </div>
      <div class="user">
        <svg class="mr-3" xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="#008894" class="bi bi-person-circle" viewBox="0 0 16 16">
          <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
          <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
        </svg>
        <a class="navbar-brand ml-5 p-2"> Admin <%= user.first_name %></a>
      </div>
    </div>
  </div>
  <div class="left-div">
    <div class="container mt-2 p-2">
      <a class="link-div" href="/users">Dashboard</a>
    </div>
    <div class="container mt-2 p-2">
      <a class="link-div" href="/users/list">Physicians</a>
    </div>
    <div class="container mt-2 p-2">
      <a class="link-div" href="/users/patients">Patients</a>
    </div>
    <div class="container mt-2 p-2">
      <a class="link-div" href="/users/devices">Devices</a>
    </div>
    <div class="container mt-2 p-2">
      <a class="btn btn-custom" style="width: 100%; font-size: 20px; color: white;" href="/users/logout">Logout</a>
    </div>
  </div>
  
  <div class="right-div">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/users/addpatient">New Patient</a></li>
      </ol>
    </nav>
    <h3 class="text-center">List of Registered patients</h3>
        <div class="table-responsive">
          <table class="table mt-3 w-100">
            <thead>
              <tr style="background-color: #008894; color: white">
                <th>#</th>
                <th>First name</th>
                <th>Last name</th>
                <th>sex</th>
                <th>Age</th>
                <th>Residence</th>
                <th>Contact</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% results.forEach(function(result) { %>
                <tr>
                  <td><%= result.sn %></td>
                  <td><%= result.first_name %></td>
                  <td><%= result.last_name %></td>
                  <td><%= result.sex %></td>
                  <td><%= result.age %></td>
                  <td><%= result.residence %></td>
                  <td><%= result.contact %></td>
                  <td>
                    <!-- Delete button with data-toggle and data-target attributes -->
                    <button class="deleteBtn btn btn-danger" data-toggle="modal" data-target="#myModal" data-user-id="<%= result.id %>">Delete</button>

                    <!-- The modal -->
                    <div id="myModal" class="modal">
                      <div class="modal-content">
                        <div class="modal-header">
                          <h4 class="modal-title">Delete Patient</h4>
                        </div>
                        <div class="modal-body">
                          <p>Are you sure you want to delete this patient?</p>
                        </div>
                        <div class="modal-footer">
                          <button class="btn btn-custom" style="color: white;" id="cancelBtn">Cancel</button>
                          <button class="btn btn-danger" id="confirmBtn">Confirm</button>
                        </div>
                      </div>
                    </div>

                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
  </div>
  <script>
    // Get all delete buttons
    const deleteButtons = document.querySelectorAll(".deleteBtn");

    // Attach click event listener to each delete button
    deleteButtons.forEach((button) => {
      button.addEventListener("click", function() {
        const userId = button.getAttribute("data-user-id"); // Get the user ID from the data attribute
        openModal(userId); // Open the modal with the user ID
      });
    });
    
    // Function to open the modal and handle the confirm button click event
    function openModal(userId) {
      const modal = document.getElementById("myModal")
      const confirmBtn = document.getElementById("confirmBtn")
      const cancelBtn = document.getElementById("cancelBtn")
    
      cancelBtn.addEventListener("click", function(){
        closeModal()
        location.reload()
      })
      // Attach click event listener to the confirm button
      confirmBtn.addEventListener("click", function() {
        // Post the user ID to the backend
        const data = {user_id: userId}
        console.log(data)
        fetch("/users/addpatient/delete", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data)
        }).then((response) => {
          console.log(response)
          closeModal();
          location.reload()
        })
        .catch((error) => {
            console.log("Error deleting user:", error);
            closeModal();
          });
      });
      modal.style.display = "block";
    }

    // Function to close the modal
    function closeModal() {
      const modal = document.getElementById("myModal");
      modal.style.display = "none";
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ENjdO4Dr2bkBIFxQpeoTz1HIcje39Wm4jDKdf19U8gI4ddQ3GYNS7NTKfAdVQSZe" crossorigin="anonymous"></script>  
</body>
</html>
