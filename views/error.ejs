<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CardiNet</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-KK94CHFLLe+nY2dmCWGMq91rCGa5gtU4mk92HdvYe+M/SXH301p5ILy+dN9+nJOZ" crossorigin="anonymous">
  <style>
    body {
      background-color: #f8f9fa;
    }

    .error-container {
      margin-top: 50px;
      text-align: center;
    }

    .error-title {
      font-size: 64px;
      font-weight: bold;
      color: #dc3545;
    }

    .error-message {
      font-size: 24px;
      margin-top: 20px;
      color: #6c757d;
    }

    .error-link {
      display: block;
      margin-top: 20px;
      font-size: 18px;
      color: #007bff;
      text-decoration: none;
    }

    .error-link:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="text-center p-2" style="background-color: #008894; color: white">
    <h2>HeartCare Clinic</h2>
    <p>"Putting your heart first for a healthier life"</p>
  </div>
  <div class="container">
    <div class="error-container">
      <div class="error-title">ERROR</div>
      <div class="error-message">Oops!Error occured </div>
      <a href="/" class="btn btn-success mt-2 mb-2">Go back to home page</a>
    </div>
  </div>
</body>
</html>
