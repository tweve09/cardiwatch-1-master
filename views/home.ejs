        function map_ecg_data(ecg_data) {
            const sampling_rate = 360; // Samples per second (Hz)
            const time_scale = 1 / sampling_rate; // Time between consecutive samples (seconds)

            // Calculate the time axis for the ECG data
            const time_axis = ecg_data.map((_, index) => index * time_scale);

            // Create a trace for the ECG data
            const ecg_trace = {
                x: time_axis,
                y: ecg_data,
                mode: 'lines',
                line: {
                    color: 'green',
                    width: 2
                },
                name: 'ECG Data From patient'
            };

