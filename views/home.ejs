<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CardiNet</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-KK94CHFLLe+nY2dmCWGMq91rCGa5gtU4mk92HdvYe+M/SXH301p5ILy+dN9+nJOZ" crossorigin="anonymous">
    <style>
      body {
        background-color: white;
      }
      .nav{
        background-color: #f8f9fa;
        height: 70px;
      }
      .ecg-plot{
        background-color: white;
        border-radius: 8px;
        box-shadow: 0 2px 3px 3px rgba(93, 92, 92,0.1);
      }
      .heart-rate{
        margin-top: 60px;
        text-align: center;
      }
      .heart-rate h1{
        font-size: 70px;
      }
      .patient-info{
        display: flex;
        justify-content: space-between;
        
      }

      .floating-button {
        position: fixed;
        right: 40px;
        bottom: 40px; 
        background-color: #f8f9fa;
        box-shadow: 0 3px 3px 0 rgba(0,0,0,0.1);
        border-radius: 6px;
      }
      
      .floating-button button {
        display: block;
        padding: 10px 20px;
        border: none;
        color: #008894;
        
      }

      .floating-button:hover{
        background: #e8f3f5;
        box-shadow: 0 4px 4px 3px rgba(0, 0, 0, 0.2);
      }
      .content-upper{
        height: calc(100vh - 70px);
      }
      .btn-custom{
        background-color: #008894;
      }
      .btn-custom:hover {
        background-color: #05b0bf;
      }

      #ecgChart {
            width: 500px;
            height: 400px;
        }
    </style>
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
  </head>
  <body>
    <!-- navbar -->
    <nav class="navbar navbar-expand-lg navbar-light nav">
      <div class="container-fluid">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="#008894" class="bi bi-heart-pulse-fill" viewBox="0 0 16 16">
            <path d="M1.475 9C2.702 10.84 4.779 12.871 8 15c3.221-2.129 5.298-4.16 6.525-6H12a.5.5 0 0 1-.464-.314l-1.457-3.642-1.598 5.593a.5.5 0 0 1-.945.049L5.889 6.568l-1.473 2.21A.5.5 0 0 1 4 9H1.475Z"/>
            <path d="M.88 8C-2.427 1.68 4.41-2 7.823 1.143c.06.055.119.112.176.171a3.12 3.12 0 0 1 .176-.17C11.59-2 18.426 1.68 15.12 8h-2.783l-1.874-4.686a.5.5 0 0 0-.945.049L7.921 8.956 6.464 5.314a.5.5 0 0 0-.88-.091L3.732 8H.88Z"/>
          </svg>
          <a class="navbar-brand ml-5 bold" >CardiNet</a>
        </div>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse mr-5" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <svg class="mr-3" xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="#008894" class="bi bi-person-circle" viewBox="0 0 16 16">
                  <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                  <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                </svg>
                Dr. <%= user.first_name %> <%= user.last_name %> 
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Profile</a></li>
                <li><a class="dropdown-item" href="/users/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav> 
    <div class="container content-upper">
      <h4 class="mt-2 font-weight-bold">Welcome , Dr. <%= user.first_name %> <%= user.last_name %> </h4>
      <p class="mr-5 font-weight-bold" id="date"></p>
      <div class="row">
        <div class="col-lg-6">
          <div class="row">
            <div class="col-lg-8">
              <p>Connection status: <span id="connection">Disconnected</span></p>
              <div id="ecgChart"></div>
            </div>
            <div class="heart-rate col-lg-4">
              <h1 id="heart_rate">00</h1>
              <p>bpm</p>
            </div>
          </div>
          
        </div>
        <div class="col-lg-6">
          <div class="rounded p-2 text-center" style="background-color: #f8f9fa;">
            <h4>Patient Information</h4>
          </div>
          <div class="patient-info">
            <p>Name: <%= results[0].first_name %> <%= results[0].last_name %></p>
            <p>Sex: <%= results[0].sex %></p>
            <p>Age: <%= results[0].age %></p>
          </div>
          <div class="patient-info">
            <p>Residence: <%= results[0].residence %></p>
            <p>Contact1: <%= results[0].contact %></p>
            <p id="patient-id" style="display: none;"><%=results[0].id %></p>
          </div>

          <div class="text-center">
            <div class="mb-3">
              <div class="rounded p-2" style="background-color: #f8f9fa;">
                <h4>Heart rate analysis</h4>
              </div>
                <table class="table">
                  <thead>
                    <tr>
                      <th>Description</th>
                      <th>Value(Bpm)</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Maximum recorded</td>
                      <td>130</td>
                    </tr>
                    <tr>
                      <td>Manimum recorded</td>
                      <td>60</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div class="mb-3">
                <form action="/detail/database" method="POST">
                  <input type="hidden" name="patient_id" value="<%= results[0].id %>">
                  <button class="btn btn-custom btn-success" type="submit">View Patient database</button>
                </form>
              </div>

             <!--  <a class="btn btn-custom btn-success mb-3" href="/detail/heart-rate">Heart rate graph</a> -->
            </div>
          </div>
        </div>
      </div>
    </div>
      <div class="floating-button">
        <button id="leave-room" data-patient-id="<%= results[0].id %>">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="#008894" class="bi bi-list-ul" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M5 11.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm-3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm0 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm0 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
          </svg>
          Patients List
        </button>
      </div>      
    <script src="/socket.io/socket.io.js"></script>
