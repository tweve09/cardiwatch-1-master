#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
const { getData, clearData } = require('../controllers/socket-conf');
var debug = require('debug')('cardiwatch-1:server');
var http = require('http');

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */
const { Server } = require("socket.io");
var server = http.createServer(app);
const io = new Server(server, { });


/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

io.on("connection", (socket) => {
    console.log("Client connected to the socket");

    socket.on('joinRoom', (patientId) => {
      const roomName = `patient-${patientId}`;
      socket.join(roomName);
      console.log(`Physician joined room ${roomName}`);
    });

    setInterval(function(){
      const data = getData();
      if(Object.keys(data).length !== 0 ){
        const patientId = data.device_id
        var roomName = `patient-${patientId}`;
        io.to(roomName).emit("patientData",JSON.stringify(data));
        console.log(`Broadcasting to room: ${roomName}`)
        clearData(data);
      }
    },5000);

    socket.on("leaveRoom", (patientId)=>{
      const roomName = `patient-${patientId}`;
      socket.leave(roomName);
      console.log(`Physician leave room ${roomName}`)
    })
}); 


/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
}

